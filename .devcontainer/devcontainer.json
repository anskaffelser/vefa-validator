{
    "name": "Java 21 Dev Container",
    "build": {
        "dockerfile": "Dockerfile",
        "args": {
            "INSTALL_MAVEN": "true",
            "MAVEN_VERSION": "3.9.15",
            "INSTALL_GRADLE": "false",
            "GRADLE_VERSION": "",
            "INSTALL_NODE": "false",
            "NODE_VERSION": "lts/*"
        }
    },
    "postCreateCommand": "bash -lc 'source /home/vscode/.sdkman/bin/sdkman-init.sh && java -version && mvn -version'",
    "settings": {
        "terminal.integrated.shell.linux": "/bin/bash",
        "java.home": "/home/vscode/.sdkman/candidates/java/current",
        "java.import.gradle.java.home": "${env:JAVA_HOME}",
        "java.configuration.runtimes": [
            {
                "default": true,
                "name": "JavaSE-21",
                "path": "${env:JAVA_HOME}"
            }
        ]
    },
    "extensions": [
        "vscjava.vscode-java-pack"
    ]
}